# =========================================================================
# CONFIGURATION TEMPLATE - PANTAUBOLA
# Salin file ini menjadi .env dan isi nilai yang sesuai.
# =========================================================================

# Supabase Credentials (Untuk Python Pipeline dan Next.js)
SUPABASE_URL=https://your-project.supabase.co
# PENTING: SUPABASE_SERVICE_KEY hanya digunakan oleh backend Python (pipeline)
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Supabase Anon Credentials (Untuk Next.js Client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# AI & Football API Keys (Untuk Python Pipeline)
GEMINI_API_KEY=your-gemini-api-key
FOOTBALL_DATA_API_KEY=your-football-data-api-key

# API-Football Key (Opsional)
API_FOOTBALL_KEY=your-api-football-key

# Telegram Alerts (Untuk Pipeline Status Webhook)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
